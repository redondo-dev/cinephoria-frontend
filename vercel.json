{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist/frontend/browser",
  "framework": "angular",
  "installCommand": "npm install",
  "functions": {
    "dist/frontend/browser/**": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
